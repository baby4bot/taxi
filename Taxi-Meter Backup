            document.getElementById('banUserBtn').style.display = 'flex'; const banBtn = document.getElementById('banUserBtn'); const banIcon = document.getElementById('banIcon'); const banText = document.getElementById('banText');
            if(isBannedState) { banBtn.style.background = 'var(--neon-green)'; banIcon.innerText = 'check_circle'; banText.innerText = 'ปลดระงับการใช้งาน'; } 
            else { banBtn.style.background = 'var(--accent-red)'; banIcon.innerText = 'block'; banText.innerText = 'ระงับการใช้งาน (Ban)'; }
        } else { document.getElementById('banUserBtn').style.display = 'none'; }
        
        let canDeleteThisUser = isGod || (myPerms.canDelete && u.role !== "Admin");
        document.getElementById('deleteUserBtn').style.display = canDeleteThisUser ? 'flex' : 'none'; 
        
        window.toggleModal('adminEditUserModal', true);
    };

    window.saveAdminUserEdit = async () => {
        const uid = document.getElementById('adminEditUid').value; const newUsername = document.getElementById('adminEditUsername').value.trim(); const newName = document.getElementById('adminEditName').value; const newRole = document.getElementById('adminEditRole').value; const newPassword = document.getElementById('adminEditPassword').value; const fileInput = document.getElementById('adminUploadPicInput'); const qrInput = document.getElementById('adminUploadQrInput'); const btn = document.getElementById('saveAdminUserBtn'); btn.innerText = "กำลังบันทึก..."; btn.disabled = true;
        try {
            let photoUpdate = document.getElementById('adminEditPic').src;
            if(photoUpdate === window.DEFAULT_AVATAR) photoUpdate = "";
            let qrUpdate = document.getElementById('adminEditQrPic').src;
            if(qrUpdate === window.DEFAULT_QR) qrUpdate = "";

            if(uid === "") {
                if (!newUsername || !newPassword || !newName) { btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 20px;">save</span> บันทึก`; btn.disabled = false; return window.showToast("กรุณากรอกข้อมูลให้ครบถ้วน", true); }
                if (newPassword.length < 1) { btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 20px;">save</span> บันทึก`; btn.disabled = false; return window.showToast("รหัสผ่านต้องมีอย่างน้อย 1 ตัวอักษร", true); }
                const q = query(collection(db, "users"), where("username", "==", newUsername)); const existCheck = await getDocs(q);
                if (!existCheck.empty) { btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 20px;">save</span> บันทึก`; btn.disabled = false; return window.showToast("Username นี้ถูกใช้งานแล้ว", true); }
                
                if (fileInput.files && fileInput.files.length > 0) { photoUpdate = await fileToBase64(fileInput.files[0]); }
                if (qrInput.files && qrInput.files.length > 0) { qrUpdate = await fileToBase64(qrInput.files[0], true); }
                
                await addDoc(collection(db, "users"), { username: newUsername, password: newPassword, displayName: newName, role: newRole, photoURL: photoUpdate, qrCodeURL: qrUpdate, isOnline: false, isBanned: false, lastLoginAt: null, order: Date.now() });
                await recordActivityLog(loggedInUserId, "เพิ่มผู้ใช้งานใหม่", `ชื่อ: ${newName}, สิทธิ์: ${newRole}`); window.showToast("สร้างผู้ใช้งานเรียบร้อย!"); window.toggleModal('adminEditUserModal', false); window.toggleModal('adminMenuModal', true); 
            } else {
                let logDetail = `แอดมินแก้ไขข้อมูล (ชื่อ: ${newName})`; let updatePayload = { displayName: newName };
                if(currentUserRole === "Admin") { updatePayload.role = newRole; logDetail += `, สิทธิ์: ${newRole}`; }
                if (newPassword.trim().length >= 1) { updatePayload.password = newPassword.trim(); logDetail += " และเปลี่ยนรหัสผ่าน"; }
                
                if (fileInput.files && fileInput.files.length > 0) { photoUpdate = await fileToBase64(fileInput.files[0]); logDetail += " และอัปเดตรูปภาพ"; }
                if (qrInput.files && qrInput.files.length > 0) { qrUpdate = await fileToBase64(qrInput.files[0], true); logDetail += " และอัปเดต QR Code"; }
                
                updatePayload.photoURL = photoUpdate;
                updatePayload.qrCodeURL = qrUpdate;

                await updateDoc(doc(db, "users", uid), updatePayload); await recordActivityLog(uid, "ผู้ดูแลระบบแก้ไขข้อมูล", logDetail); window.showToast("อัปเดตข้อมูลผู้ใช้เรียบร้อย!"); window.toggleModal('adminEditUserModal', false);
            }
        } catch(e) { window.showToast("เกิดข้อผิดพลาด", true); } finally { btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 20px;">save</span> บันทึก`; btn.disabled = false; }
    };

    window.deleteAdminUser = async () => {
        const uid = currentEditUid; if(uid === loggedInUserId) return window.showToast("ไม่สามารถลบบัญชีตัวเองขณะใช้งานได้", true);
        let isOk = await showCustomConfirm("ลบบัญชีผู้ใช้", "ยืนยันการ 'ลบบัญชีผู้ใช้' ถาวรใช่หรือไม่?\nผู้ใช้งานรายนี้จะไม่สามารถเข้าสู่ระบบได้อีกต่อไป", "danger", "ลบข้อมูล");
        if(isOk) { 
            try { await deleteDoc(doc(db, "users", uid)); window.showToast("ลบบัญชีผู้ใช้เรียบร้อยแล้ว"); window.toggleModal('adminEditUserModal', false); } catch(e) { window.showToast("เกิดข้อผิดพลาดในการลบข้อมูล", true); } 
        }
    };

    window.viewUserLogs = async (uid, userName) => {
        window.toggleModal('activityLogModal', true); const listDiv = document.getElementById('activityLogList'); listDiv.innerHTML = '<div style="color: var(--text-dim); text-align: center; padding: 20px;">กำลังโหลด...</div>';
        try {
            const q = query(collection(db, "users", uid, "logs"), orderBy("timestamp", "desc")); const querySnapshot = await getDocs(q);
            let html = `<div style="font-size:14px; margin-bottom:15px; color:var(--neon-yellow); text-align:center;">ประวัติของ: ${userName}</div>`;
            if(querySnapshot.empty) { html += `<div style="text-align:center; color:var(--text-dim); font-size:12px;">ไม่มีประวัติการทำรายการ</div>`; } 
            else { querySnapshot.forEach((doc) => { const data = doc.data(); html += `<div class="log-item"><div class="log-time">${formatDate(data.timestamp)}</div><div style="font-weight:600; color:white;">${data.action}</div><div style="color:#ccc; margin-top:3px;">${data.detail}</div></div>`; }); }
            listDiv.innerHTML = html;
        } catch(e) { listDiv.innerHTML = '<div style="color: var(--accent-red); text-align: center; padding: 20px;">เกิดข้อผิดพลาดในการโหลดประวัติ</div>'; }
    };

    window.openMainQrCode = () => {
        if(!window.myCurrentQrCodeURL || window.myCurrentQrCodeURL.length < 10) { window.showToast("คุณยังไม่ได้ตั้งค่า QR Code รับเงิน กรุณาตั้งค่าในเมนูโปรไฟล์", true); return; }
        document.getElementById('mainScreenQrImg').src = window.myCurrentQrCodeURL; document.getElementById('qrNameText').innerText = window.myCurrentDisplayName; toggleModal('qrOverlay', true);
    };

    // =========================================================================
    // โค้ดส่วนจัดการระบบ Service Portal
    // =========================================================================
    
    let editingServiceCatId = null;
    let editingServiceItemId = null;

    const getSmartIcon = (title) => {
        const t = title.toLowerCase();
        if(t.includes('วัน')) return 'calendar_today';
        if(t.includes('เน็ต') || t.includes('wifi') || t.includes('เนต')) return 'wifi';
        if(t.includes('โทร') || t.includes('นาที')) return 'phone';
        if(t.includes('โบนัส') || t.includes('เงิน') || t.includes('บาท')) return 'card_giftcard';
        if(t.includes('เติม') || t.includes('พิเศษ')) return 'favorite';
        if(t.includes('เจ้าของ') || t.includes('ปชช') || t.includes('บัตร')) return 'person';
        if(t.includes('ข้อความ') || t.includes('sms')) return 'message';
        if(t.includes('ยกเลิก')) return 'block';
        return 'smartphone'; 
    };

    let serviceDataUnsub = null; window.currentServiceData = []; window.currentServiceModeManage = false;
    let categorySortable = null; let itemSortables = [];

    window.openServicePortal = (isManageMode = false) => {
        window.currentServiceModeManage = isManageMode; toggleModal('servicePortalModal', true);
        let myPerms = (currentUserRole === "Admin") ? {canManageService: true} : (globalPermissions[currentUserRole] || {});
        document.getElementById('serviceModalTitle').innerText = isManageMode ? "จัดการ SERVICE PORTAL" : "SERVICE PORTAL";
        document.getElementById('adminServiceAddSection').style.display = (isManageMode && myPerms.canManageService) ? 'block' : 'none';

        if(!serviceDataUnsub) {
            serviceDataUnsub = onSnapshot(doc(db, "system", "service_data"), (docSnap) => {
                if(docSnap.exists()) { window.currentServiceData = docSnap.data().categories || []; } else { window.currentServiceData = []; }
                renderServicePortalUI();
            });
        } else { renderServicePortalUI(); }
    };

    window.renderServicePortalUI = () => {
        let isManageMode = window.currentServiceModeManage; let html = ''; let datalistHtml = '';
        if (window.currentServiceData.length === 0) { html = '<div style="text-align:center; color:gray; padding:20px;">ยังไม่มีรายการในระบบ</div>'; } 
        else {
            window.currentServiceData.forEach((cat, index) => {
                datalistHtml += `<option value="${cat.name}">`;
                let catDragHandle = isManageMode ? `<div class="drag-handle" style="display:inline-flex; align-items:center; padding-right:8px;"><span class="material-symbols-outlined" style="color:rgba(255,255,255,0.4); font-size:26px;">drag_indicator</span></div>` : `<span class="material-symbols-outlined">play_arrow</span>`;
                
                let themeClass = `theme-cat-${index % 6}`;

                html += `<div class="category-block" data-id="${cat.id}" data-name="${cat.name}"><div class="sp-cat-title title-${themeClass}">${catDragHandle} ${cat.name}</div><div class="category-items-container" data-cat="${cat.id}" style="min-height: 20px;">`; 
                
                cat.items.forEach((d) => {
                    let itemDragHandle = isManageMode ? `<div class="drag-handle" style="display:flex; align-items:center; padding-right:10px;"><span class="material-symbols-outlined" style="color: rgba(255,255,255,0.3); font-size: 26px;">drag_indicator</span></div>` : '';
                    
                    let editBtn = isManageMode ? `<button onclick="editServiceItem('${cat.id}', '${d.id}', '${cat.name}', '${d.title}', '${d.code}', event)" style="background:none; border:none; color:var(--neon-yellow); margin-left:5px; padding:5px; cursor:pointer;"><span class="material-symbols-outlined" style="font-size:24px;">edit</span></button>` : '';
                    let delBtn = isManageMode ? `<button onclick="deleteServiceItem('${cat.id}', '${d.id}', event)" style="background:none; border:none; color:var(--accent-red); margin-left:5px; padding:5px; cursor:pointer;"><span class="material-symbols-outlined" style="font-size:24px;">delete</span></button>` : '';
                    
                    let clickAction = isManageMode ? '' : `onclick="dialCode('${d.code}')" style="cursor:pointer;"`;
                    
                    html += `<div class="sp-card ${themeClass}" data-id="${d.id}" data-title="${d.title}" data-code="${d.code}">
                                ${itemDragHandle}
                                <div class="sp-info" ${clickAction}>
                                    <div class="sp-item-title">${d.title}</div>
                                    <div class="sp-code">${d.code}</div>
                                </div>
                                <div class="sp-icon-box"><span class="material-symbols-outlined">${d.icon || getSmartIcon(d.title)}</span></div>
                                <div style="display:flex;">${editBtn}${delBtn}</div>
                            </div>`;
                });
                html += `</div></div>`;
            });
        }
        document.getElementById('serviceListContainer').innerHTML = html; document.getElementById('existingCategories').innerHTML = datalistHtml;
        if(categorySortable) categorySortable.destroy(); itemSortables.forEach(s => s.destroy()); itemSortables = [];
        
        if (isManageMode) {
            let container = document.getElementById('serviceListContainer');
            categorySortable = new Sortable(container, { 
                animation: 150, handle: '.drag-handle', ghostClass: 'sortable-ghost', 
                delay: 250, delayOnTouchOnly: true, fallbackOnBody: true, swapThreshold: 0.65, 
                onEnd: () => { rebuildServiceDataAndSave(); } 
            });
            document.querySelectorAll('.category-items-container').forEach(el => { 
                let sortable = new Sortable(el, { 
                    group: 'shared', animation: 150, handle: '.drag-handle', ghostClass: 'sortable-ghost', 
                    delay: 250, delayOnTouchOnly: true, fallbackOnBody: true, swapThreshold: 0.65, 
                    onEnd: () => { rebuildServiceDataAndSave(); } 
                }); 
                itemSortables.push(sortable); 
            });
        }
    };

    window.rebuildServiceDataAndSave = async () => {
        let newData = [];
        document.querySelectorAll('.category-block').forEach(catBlock => {
            let catName = catBlock.dataset.name; let catId = catBlock.dataset.id; let items = [];
            catBlock.querySelectorAll('.sp-card').forEach(card => { 
                let iconStr = card.querySelector('.sp-icon-box .material-symbols-outlined').innerText;
                items.push({ id: card.dataset.id, title: card.dataset.title, code: card.dataset.code, icon: iconStr }); 
            });
            if(items.length > 0) { newData.push({ id: catId, name: catName, items: items }); }
        });
        try { await setDoc(doc(db, "system", "service_data"), { categories: newData }); } catch(e) { window.showToast("อัปเดตลำดับล้มเหลว", true); }
    };

    window.dialCode = (code) => { let dialStr = code.replace(/#/g, '%23'); window.location.href = `tel:${dialStr}`; };

    window.editServiceItem = (catId, itemId, catName, title, code, event) => {
        event.stopPropagation();
        editingServiceCatId = catId; editingServiceItemId = itemId;
        document.getElementById('newServiceCategory').value = catName;
        document.getElementById('newServiceTitle').value = title;
        document.getElementById('newServiceCode').value = code;
        
        let btn = document.getElementById('addServiceBtn');
        btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 18px;">save</span> บันทึกการแก้ไข`;
        btn.style.background = 'var(--neon-yellow)'; btn.style.color = 'black';
        document.getElementById('cancelEditBtn').style.display = 'block';
        document.getElementById('adminServiceAddSection').scrollIntoView({behavior: "smooth"});
    };

    window.cancelEditService = () => {
        editingServiceCatId = null; editingServiceItemId = null;
        document.getElementById('newServiceCategory').value = '';
        document.getElementById('newServiceTitle').value = '';
        document.getElementById('newServiceCode').value = '';
        
        let btn = document.getElementById('addServiceBtn');
        btn.innerHTML = `<span class="material-symbols-outlined" style="font-size: 18px;">add_circle</span> เพิ่มรายการเข้าสู่ระบบ`;
        btn.style.background = 'var(--neon-green)'; btn.style.color = 'white';
        document.getElementById('cancelEditBtn').style.display = 'none';
    };

    window.addNewServiceCode = async () => {
        let catName = document.getElementById('newServiceCategory').value.trim() || 'ทั่วไป'; 
        let title = document.getElementById('newServiceTitle').value.trim(); 
        let code = document.getElementById('newServiceCode').value.trim();
        if(!title || !code) return window.showToast("กรุณากรอกชื่อและรหัสให้ครบ", true);
        
        let newData = JSON.parse(JSON.stringify(window.currentServiceData)); 
        
        if (editingServiceItemId && editingServiceCatId) {
            let oldCatIndex = newData.findIndex(c => c.id === editingServiceCatId);
            if (oldCatIndex !== -1) {
                newData[oldCatIndex].items = newData[oldCatIndex].items.filter(i => i.id !== editingServiceItemId);
                if(newData[oldCatIndex].items.length === 0) newData.splice(oldCatIndex, 1);
            }
            let newCatIndex = newData.findIndex(c => c.name === catName);
            if(newCatIndex === -1) { newData.push({ id: 'cat_' + Date.now(), name: catName, items: [] }); newCatIndex = newData.length - 1; }
            newData[newCatIndex].items.push({ id: editingServiceItemId, title: title, code: code, icon: getSmartIcon(title) });
            try { 
                await setDoc(doc(db, "system", "service_data"), { categories: newData }); 
                window.showToast("แก้ไขรายการสำเร็จ!"); await recordActivityLog(loggedInUserId, "แก้ไข Service Code", `แก้ไข: ${title}`); 
                cancelEditService();
            } catch(e) { window.showToast("เกิดข้อผิดพลาด", true); }
        } else {
            let catIndex = newData.findIndex(c => c.name === catName);
            if(catIndex === -1) { newData.push({ id: 'cat_' + Date.now(), name: catName, items: [] }); catIndex = newData.length - 1; }
            newData[catIndex].items.push({ id: 'item_' + Date.now(), title: title, code: code, icon: getSmartIcon(title) });
            try { 
                await setDoc(doc(db, "system", "service_data"), { categories: newData }); 
                document.getElementById('newServiceTitle').value = ''; document.getElementById('newServiceCode').value = ''; 
                window.showToast("เพิ่มรายการสำเร็จ!"); await recordActivityLog(loggedInUserId, "เพิ่ม Service Code", `เพิ่ม: ${title}`); 
            } catch(e) { window.showToast("เกิดข้อผิดพลาด", true); }
        }
    };

    window.deleteServiceItem = async (catId, itemId, event) => {
        event.stopPropagation();
        let isOk = await showCustomConfirm("ลบรายการ", "ต้องการลบรายการนี้ใช่หรือไม่?", "danger");
        if(isOk) {
            let newData = JSON.parse(JSON.stringify(window.currentServiceData)); let catIndex = newData.findIndex(c => c.id === catId);
            if(catIndex !== -1) {
                newData[catIndex].items = newData[catIndex].items.filter(i => i.id !== itemId);
                if(newData[catIndex].items.length === 0) { newData.splice(catIndex, 1); } 
            }
            try { await setDoc(doc(db, "system", "service_data"), { categories: newData }); window.showToast("ลบเรียบร้อย"); cancelEditService(); } catch(e) {}
        }
    };
</script>
</body>
</html>
