        .side-user-role { font-size: 15px; font-weight: 600; color: #f39c12; margin-top: 2px; }
        .side-divider { border: 0; height: 1px; background: rgba(255,255,255,0.08); margin: 20px 0; width: 100%; }
        .side-menu-items { flex: 1; display: flex; flex-direction: column; gap: 5px; }
