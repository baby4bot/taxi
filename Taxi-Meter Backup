<script>
    // สคริปต์สำหรับการสลับซ่อน/แสดงรหัสผ่าน
    window.togglePasswordVisibility = function(inputId, iconEl) {
        const input = document.getElementById(inputId);
        if (input.type === "password") {
            input.type = "text";
            iconEl.innerText = "visibility";
        } else {
            input.type = "password";
            iconEl.innerText = "visibility_off";
        }
    };

    window.updateAppManifest = function(userName, photoUrl) {
        let safeName = userName ? userName : "Taxi 2026";
        let safeIcon = (photoUrl && photoUrl.length > 10) ? photoUrl : "https://i.ibb.co/spwbY6g9/abb8123a-07ff-4222-a85e-15b8024c0b75.jpg";

        document.getElementById('appleIcon').href = safeIcon;
        document.getElementById('shortcutIcon').href = safeIcon;

        let manifest = {
            "name": "Taxi: " + safeName,
            "short_name": safeName,
            "start_url": ".",
            "display": "standalone",
            "background_color": "#090a0f",
            "theme_color": "#090a0f",
            "icons": [
                {
                    "src": safeIcon,
                    "sizes": "192x192",
                    "type": "image/jpeg"
                },
                {
                    "src": safeIcon,
                    "sizes": "512x512",
                    "type": "image/jpeg"
                }
            ]
        };

        let stringManifest = JSON.stringify(manifest);
        let manifestURI = 'data:application/manifest+json,' + encodeURIComponent(stringManifest);
        
        let manifestLink = document.getElementById('dynamicManifest');
        if (manifestLink) {
            manifestLink.href = manifestURI;
        }
    };

    // =======================================================
    // ระบบ Custom Confirm
    // =======================================================
    window.showCustomConfirm = function(title, desc, type = 'warning', okText = 'ยืนยัน') {
        return new Promise((resolve) => {
            const overlay = document.getElementById('sysCustomConfirm');
            const icon = document.getElementById('ccIcon');
            const btnOk = document.getElementById('ccBtnOk');
            const btnCancel = document.getElementById('ccBtnCancel');

            document.getElementById('ccTitle').innerText = title;
            document.getElementById('ccDesc').innerText = desc;
            btnOk.innerText = okText;

            if(type === 'danger') {
                icon.className = "material-symbols-outlined custom-confirm-icon danger";
                icon.innerText = "error";
                btnOk.className = "btn-cc-ok danger";
            } else {
                icon.className = "material-symbols-outlined custom-confirm-icon warning";
                icon.innerText = "help";
                btnOk.className = "btn-cc-ok";
            }

            overlay.style.display = 'flex';

            btnOk.onclick = () => {
                overlay.style.display = 'none';
                resolve(true); 
            };

            btnCancel.onclick = () => {
                overlay.style.display = 'none';
                resolve(false); 
            };
        });
    };

    const HISTORY_KEY = 'taxi_history_v25';
    const $ = id => document.getElementById(id);
    let destLoc = null, searchTimer = null, totalKm = 0, etaSec = 0, watchId = null;
    let lastPos = null, actualDrivenKm = 0, startTime = null, wakeLock = null, lastCalcTime = null;
    let tripTimer = null, routeUpdateTimer = null, trafficSeconds = 0;
    let lastPosTime = null, currentSpeedKmh = 0, currentTrueRemainKm = 0, currentTrueRemainSec = 0; 
    let isManualRunning = false;
    
    async function requestWakeLock() { try { if ('wakeLock' in navigator) wakeLock = await navigator.wakeLock.request('screen'); } catch (err) {} }
    function releaseWakeLock() { if (wakeLock !== null) { wakeLock.release().catch(()=>{}); wakeLock = null; } }
    document.addEventListener('visibilitychange', () => { if (document.visibilityState === 'visible' && isManualRunning) requestWakeLock(); });
    const calcGPS = (l1, n1, l2, n2) => 6371 * 2 * Math.asin(Math.sqrt(Math.sin((l2-l1)*Math.PI/360)**2 + Math.cos(l1*Math.PI/180)*Math.cos(l2*Math.PI/180)*Math.sin((n2-n1)*Math.PI/360)**2));
    function formatDuration(totalMins) { if (totalMins < 60) return totalMins + " นาที"; let h = Math.floor(totalMins / 60); let m = totalMins % 60; return h + " ชม. " + (m > 0 ? m + " นาที" : ""); }

    window.toggleSideMenu = (show) => {
        const overlay = $('sideMenuOverlay'); const box = $('sideMenuBox');
        if (show) { overlay.style.display = 'block'; setTimeout(() => { overlay.style.opacity = '1'; box.style.right = '0'; }, 10); } 
        else { overlay.style.opacity = '0'; box.style.right = '-320px'; setTimeout(() => { overlay.style.display = 'none'; }, 300); }
    };

    window.toggleModal = (id, show) => {
        $(id).style.display = show ? 'flex' : 'none';
        if(id === 'zoomOverlay' && show) { $('zoomPrice').innerHTML = $('farePrice').innerHTML; $('zoomKm').innerText = $('infoText').innerText; }
        if(id === 'adminMenuModal' && window.handleAdminModalState) window.handleAdminModalState(show);
    };

    window.openChangePasswordModal = () => {
        $('oldPassword').value = ''; $('newPassword').value = ''; $('confirmPassword').value = '';
        $('oldPassword').type = 'password'; $('newPassword').type = 'password'; $('confirmPassword').type = 'password';
        document.querySelectorAll('#changePasswordModal .toggle-password').forEach(icon => icon.innerText = 'visibility_off');
        $('cpProfilePic').src = $('editProfilePic').src; toggleModal('changePasswordModal', true);
    };

    window.saveHistory = (name, lat, lon) => { let h = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]').filter(i => i.name !== name); h.unshift({ name, lat, lon }); localStorage.setItem(HISTORY_KEY, JSON.stringify(h.slice(0, 10))); };
    window.showHistory = () => { let h = JSON.parse(localStorage.getItem(HISTORY_KEY) || '[]'); if (!h.length) return $('historyList').style.display = 'none'; $('suggestionList').style.display = 'none'; $('historyList').innerHTML = `<div class="history-header"><span><span class="material-symbols-outlined">history</span> ประวัติล่าสุด</span><button class="clear-history-btn" onclick="event.stopPropagation(); localStorage.removeItem('${HISTORY_KEY}'); $('historyList').style.display='none';">ล้าง</button></div>` + h.map(i => `<div class="list-item" onclick="selectLocation('${i.name}', ${i.lat}, ${i.lon})"><span class="material-symbols-outlined item-icon">location_on</span>${i.name}</div>`).join(''); $('historyList').style.display = 'block'; };
    
    // ===== ระบบ Smart Search (AI แบบ Rule-based จับรูปแบบคำ) =====
    const formatSearchText = (text) => {
        let t = text.trim();

        t = t.replace(/(^|\s)รพ\.?\s*/g, "$1โรงพยาบาล ");
        t = t.replace(/(^|\s)รร\.?\s*/g, "$1โรงเรียน ");
        t = t.replace(/(^|\s)ม\.?\s*(ราม|เกษตร|กรุงเทพ|ธรรมศาสตร์|มหิดล|จุฬา|ศิลปากร|รังสิต|หอการค้า)/g, "$1มหาวิทยาลัย$2");
        t = t.replace(/(^|\s)(มบ\.?|ม\.)\s*/g, "$1หมู่บ้าน "); 

        t = t.replace(/(^|\s)ราม\s*(\d+)/g, "$1รามคำแหง $2");
        t = t.replace(/(^|\s)พหล\s*(\d+)/g, "$1พหลโยธิน $2");
        t = t.replace(/(^|\s)สุขุม\s*(\d+)/g, "$1สุขุมวิท $2");
        t = t.replace(/(^|\s)รัชดา\s*(\d+)/g, "$1รัชดาภิเษก $2");
        t = t.replace(/(^|\s)จรัญ\s*(\d+)/g, "$1จรัญสนิทวงศ์ $2");
        t = t.replace(/(^|\s)วิภา\s*(\d+)/g, "$1วิภาวดีรังสิต $2");

        t = t.replace(/ซอย\s*/g, ""); 
        const soiRoads = ["รามคำแหง", "ลาดพร้าว", "สุขุมวิท", "พหลโยธิน", "เพชรเกษม", "รัชดาภิเษก", "อ่อนนุช", "เอกมัย", "ทองหล่อ", "พัฒนาการ", "ศรีนครินทร์", "จรัญสนิทวงศ์", "วิภาวดีรังสิต", "นวมินทร์", "บางนา-ตราด", "รามอินทรา", "เพชรบุรี", "พระราม 1", "พระราม 2", "พระราม 3", "พระราม 4", "พระราม 5", "พระราม 6", "พระราม 7", "พระราม 8", "พระราม 9", "เจริญกรุง", "ประชาอุทิศ", "งามวงศ์วาน", "แจ้งวัฒนะ", "ติวานนท์", "ลาดกระบัง", "เสรีไทย", "รามอินทรา", "บางแค", "เพชรเกษม", "บางบอน"];
        const roadRegex = new RegExp(`(^|\\s)(${soiRoads.join('|')})\\s*(\\d+)([\\s\\/]*)`, 'g');
        t = t.replace(roadRegex, "$1ซอย$2 $3$4");

        const dictionary = {
            "เซ็นทรัลปิ่นเกล้า": "เซ็นทรัล ปิ่นเกล้า",
            "เซนปิ่น": "เซ็นทรัล ปิ่นเกล้า",
            "เซนลาด": "เซ็นทรัล ลาดพร้าว",
            "เซ็นลาด": "เซ็นทรัล ลาดพร้าว",
            "เดอะมอลล์บางกะปิ": "เดอะมอลล์ บางกะปิ",
            "สายใต้ใหม่": "สถานีขนส่งผู้โดยสารกรุงเทพ (สายใต้ใหม่)",
            "หมอชิต": "สถานีขนส่งผู้โดยสารกรุงเทพ (จตุจักร)",
            "ฟิวเจอร์": "ฟิวเจอร์พาร์ค รังสิต",
            "แฟชั่น": "แฟชั่นไอส์แลนด์",
            "สุวรรณภูมิ": "ท่าอากาศยานสุวรรณภูมิ",
            "ดอนเมือง": "ท่าอากาศยานดอนเมือง",
            "อนุสาวรีย์": "อนุสาวรีย์ชัยสมรภูมิ"
        };

        for (const [key, value] of Object.entries(dictionary)) {
            t = t.replace(new RegExp(key, "gi"), value);
        }

        return t.trim();
    };

    window.smartSearch = (q) => { 
        clearTimeout(searchTimer); 
        const list = $('suggestionList'); 
        $('historyList').style.display = 'none'; 
        if (!(q = q.trim())) return list.style.display = 'none'; 

        const smartQuery = formatSearchText(q);

        searchTimer = setTimeout(async () => { 
            try { 
                let res = await (await fetch(`https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(smartQuery)}&countrycodes=th&limit=8&accept-language=th`)).json(); 
                if(!res.length) return (list.innerHTML = '<div style="padding:15px; text-align:center;">ไม่พบข้อมูลสถานที่<br><span style="font-size:12px;color:gray;">(ลองระบุเขตหรือแขวงเพิ่มดูนะครับ)</span></div>', list.style.display = 'block'); 
                list.innerHTML = res.map(i => `<div class="list-item" onclick="selectLocation('${i.display_name.split(',')[0]}', ${i.lat}, ${i.lon})"><span class="material-symbols-outlined item-icon">location_on</span><div style="flex:1;">${i.display_name}</div></div>`).join(''); 
                list.style.display = 'block'; 
            } catch(e) {} 
        }, 800); 
    };
    // =================================================================

    window.selectLocation = (name, lat, lon) => { clearTimeout(searchTimer); $('destInput').value = "กำลังคำนวณ..."; $('destInput').classList.add('loading-state'); $('historyList').style.display = 'none'; $('suggestionList').style.display = 'none'; destLoc = { lat, lon }; $('searchSectionBox').style.display = 'none'; $('manualSectionBox').style.display = 'none'; saveHistory(name, lat, lon); getRouteData(lat, lon, name); };
    
    // เปลี่ยนสูตรประเมินเวลาจาก OSRM โดยตรงเพื่อความแม่นยำสูงสุดของระบบฟรี
    async function getRouteData(dLat, dLon, name) { 
        navigator.geolocation.getCurrentPosition(async (pos) => { 
            let startPos = { lat: pos.coords.latitude, lon: pos.coords.longitude }; 
            try { 
                let data = await (await fetch(`https://router.project-osrm.org/route/v1/driving/${startPos.lon},${startPos.lat};${dLon},${dLat}?overview=false`)).json(); 
                if (data.code === 'Ok') { 
                    let km = data.routes[0].distance / 1000; 
                    currentTrueRemainKm = km; 
                    currentTrueRemainSec = data.routes[0].duration; // ใช้เวลาจริงจากเส้นทาง
                    processRoute(km, currentTrueRemainSec, name); 
                } else { 
                    alert('ไม่สามารถคำนวณเส้นทางได้'); resetAll(); 
                } 
            } catch(e) { 
                alert('เกิดข้อผิดพลาดในการดึงข้อมูลเส้นทาง'); resetAll(); 
            } 
        }, () => { 
            alert('กรุณาเปิด GPS'); resetAll(); 
        }, { enableHighAccuracy: true }); 
    }
    
    function processRoute(km, sec, name) { totalKm = km; etaSec = sec; $('kmInput').value = km.toFixed(2); $('destInput').value = name; $('destInput').classList.remove('loading-state'); updateFareBubble(km); checkAppStatus(); startMeterAndTracking(); }
    
    function startMeterAndTracking() {
        if (isManualRunning) return;
        isManualRunning = true; requestWakeLock();
        $('manualTimerBtn').disabled = false; $('manualTimerBtn').classList.add('active');
        $('searchSectionBox').style.display = 'none'; $('manualSectionBox').style.display = 'none'; $('resetBtn').style.display = 'none';
        if(destLoc) { $('smallNavBtn').style.display = 'flex'; $('liveTracker').style.display = 'block'; startDynamicRouting(); }
        actualDrivenKm = 0; trafficSeconds = 0; currentSpeedKmh = 0; startTime = Date.now(); lastPosTime = startTime; lastCalcTime = startTime;
        if(destLoc) { let initialMins = Math.ceil(currentTrueRemainSec / 60); let formattedEta = formatDuration(initialMins); let initialArrTime = new Date(Date.now() + initialMins * 60000).toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'}); $('arrivalTime').innerText = initialArrTime; $('smallEtaTime').innerText = formattedEta; }
        navigator.geolocation.getCurrentPosition(pos => { lastPos = { lat: pos.coords.latitude, lon: pos.coords.longitude }; }, null, { enableHighAccuracy: true });
        if(tripTimer) clearInterval(tripTimer);
        tripTimer = setInterval(() => { let now = Date.now(); let elapsedSec = Math.floor((now - startTime) / 1000); let eMins = Math.floor(elapsedSec / 60); let eSecs = elapsedSec % 60; let deltaSec = (now - lastCalcTime) / 1000; lastCalcTime = now; if (now - lastPosTime > 5000) currentSpeedKmh = 0; if (currentSpeedKmh <= 6) trafficSeconds += deltaSec; if(currentTrueRemainSec > 0) { currentTrueRemainSec -= deltaSec; if(currentTrueRemainSec < 0) currentTrueRemainSec = 0; } updateLiveMeterDisplay(); }, 1000);
        if(watchId) navigator.geolocation.clearWatch(watchId);
        watchId = navigator.geolocation.watchPosition((pos) => { let now = Date.now(); if (lastPos) { let dMoved = calcGPS(lastPos.lat, lastPos.lon, pos.coords.latitude, pos.coords.longitude); let timeHours = (now - lastPosTime) / 3600000; if (timeHours > 0) currentSpeedKmh = dMoved / timeHours; if (dMoved > 0.002) { actualDrivenKm += dMoved; currentTrueRemainKm -= dMoved; if(currentTrueRemainKm < 0) currentTrueRemainKm = 0; lastPos = { lat: pos.coords.latitude, lon: pos.coords.longitude }; lastPosTime = now; } } else { lastPos = { lat: pos.coords.latitude, lon: pos.coords.longitude }; lastPosTime = now; } if(destLoc) { let remainKm = currentTrueRemainKm; let totalEstimated = actualDrivenKm + remainKm; let pct = totalEstimated > 0 ? Math.min((actualDrivenKm / totalEstimated) * 100, 100) : 0; let remainMins = Math.ceil(currentTrueRemainSec / 60); if(remainMins < 1) remainMins = 1; let formattedEta = formatDuration(remainMins); let dStr = actualDrivenKm.toFixed(2); let rStr = remainKm.toFixed(2); $('driveCovered').innerText = dStr; $('driveRemain').innerText = rStr; $('progressFill').style.width = pct + '%'; $('carIcon').style.left = pct + '%'; $('arrivalTime').innerText = new Date(Date.now() + remainMins * 60000).toLocaleTimeString('th-TH', {hour:'2-digit', minute:'2-digit'}); $('smallEtaTime').innerText = formattedEta; } }, null, { enableHighAccuracy: true, timeout: 5000, maximumAge: 0 });
        updateLiveMeterDisplay();
