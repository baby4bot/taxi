        .side-menu-item:hover { background: rgba(255,255,255,0.05); transform: translateX(5px); }
        .side-menu-item .material-symbols-outlined { color: #f1c40f; font-size: 24px; }
        .side-menu-item.logout-item { color: #ff4757; margin-top: auto; }
        .side-menu-item.logout-item .material-symbols-outlined { color: #ff4757; }

