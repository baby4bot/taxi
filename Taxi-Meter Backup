        .btn-close-floating { position: absolute; top: 50%; right: 15px; transform: translateY(-50%); width: 36px; height: 36px; background: var(--accent-red); color: white; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 24px; font-weight: bold; cursor: pointer; z-index: 10001; border: 2px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.4); -webkit-tap-highlight-color: transparent; transition: 0.2s; }
        .btn-close-floating:active { transform: translateY(-50%) scale(0.9); }
        .btn-action-floating { position: absolute; top: 50%; right: 60px; transform: translateY(-50%); width: 36px; height: 36px; background: #ff9800; color: white; border-radius: 50%; display: flex; justify-content: center; align-items: center; font-size: 20px; font-weight: bold; cursor: pointer; z-index: 10001; border: 2px solid white; box-shadow: 0 4px 10px rgba(0,0,0,0.4); -webkit-tap-highlight-color: transparent; transition: 0.2s; }
