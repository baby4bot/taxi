        .clear-history-btn { background: rgba(255, 71, 87, 0.1); color: var(--accent-red); padding: 6px 14px; border-radius: 10px; font-size: 11px; cursor: pointer; border: 1px solid rgba(255, 71, 87, 0.3); font-weight: 600; }
        .list-item { padding: 16px; cursor: pointer; border-bottom: 1px solid rgba(255,255,255,0.03); text-align: left; font-size: 14px; display: flex; align-items: center; gap: 12px; transition: 0.2s; }
        .list-item:hover { background: rgba(255,255,255,0.05); }
        .item-icon { font-size: 20px !important; color: var(--neon-green); text-shadow: 0 0 10px rgba(46, 204, 113, 0.4); flex-shrink: 0; }

        .live-tracker-box { flex-shrink: 0; display: none; cursor: pointer; background: rgba(0,0,0,0.3); border: 1px solid var(--border-glass); border-radius: 20px; padding: 15px; margin-top: 10px; text-align: center; box-shadow: inset 0 2px 10px rgba(0,0,0,0.5); transition: 0.3s; animation: fadeIn 0.5s ease; }
        .live-tracker-box:active { transform: scale(0.97); }
        .tracker-stats { display: flex; justify-content: space-between; font-size: 12px; color: var(--text-dim); margin-bottom: 10px; }
        .highlight { color: var(--neon-green); font-weight: 600; text-shadow: 0 0 5px var(--glow-green); }
        
        .progress-line { position: relative; width: 100%; height: 6px; background: rgba(255,255,255,0.1); border-radius: 3px; margin: 15px 0; }
        .progress-fill { position: absolute; top: 0; left: 0; height: 100%; background: linear-gradient(90deg, var(--neon-green), var(--neon-yellow)); border-radius: 3px; width: 0%; transition: width 1s ease-out; box-shadow: 0 0 10px var(--glow-yellow); }
        
        .car-icon { position: absolute; top: -16px; left: 0%; transform: translateX(-50%); transition: left 1s ease-out; z-index: 2; display: flex; justify-content: center; align-items: center; }
        .point-dot { position: absolute; top: -3px; width: 12px; height: 12px; border-radius: 50%; background: var(--bg-dark); border: 2px solid; z-index: 1; }
        
        .manual-section { flex-shrink: 0; display: flex; align-items: center; gap: 12px; margin: 10px auto; width: 100%; justify-content: center; position: relative; z-index: 20; }
        .btn-math { width: 60px; height: 60px; border-radius: 20px; font-size: 30px; cursor: pointer; flex-shrink: 0; border: none; color: white; transition: 0.2s; -webkit-user-select: none; user-select: none; -webkit-tap-highlight-color: transparent; }
        .btn-math:active { transform: scale(0.95); }
        .btn-minus { background: var(--accent-red); box-shadow: 0 4px 10px rgba(255, 71, 87, 0.3); }
        .btn-plus { background: var(--neon-green); box-shadow: 0 4px 10px rgba(46, 204, 113, 0.3); }
        .btn-math:disabled { opacity: 0.4; cursor: not-allowed; pointer-events: none; box-shadow: none; }
        
        .km-input-box { flex: 1; height: 60px; display: flex; align-items: center; overflow: hidden; transition: 0.3s; background: var(--input-bg); border: 1px solid var(--border-glass); border-radius: 20px; box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }
        input[type="number"] { width: 100%; border: none; text-align: center; font-size: 26px; outline: none; color: white; background: transparent; font-weight: 500; -moz-appearance: textfield; transition: 0.3s; }
