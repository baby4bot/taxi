    <style>
        :root {
            color-scheme: dark;
            --bg-dark: #090a0f; --card-glass: rgba(22, 24, 35, 0.65); --input-bg: rgba(0, 0, 0, 0.4);
            --neon-green: #2ecc71; --neon-yellow: #f1c40f; --accent-red: #ff4757; --accent-orange: #ff9800;
            --text-main: #ffffff; --text-dim: #a0a5b5; --border-glass: rgba(255, 255, 255, 0.08);
            --glow-green: rgba(46, 204, 113, 0.4); --glow-yellow: rgba(241, 196, 15, 0.4);
        }

        body { 
            font-family: 'Kanit', sans-serif; background-color: var(--bg-dark); margin: 0; min-height: 100vh; 
            color: var(--text-main); box-sizing: border-box; overflow-x: hidden;
            background-image: radial-gradient(circle at 15% 50%, rgba(46, 204, 113, 0.08), transparent 25%), radial-gradient(circle at 85% 30%, rgba(241, 196, 15, 0.08), transparent 25%);
        }

        .card { 
            background: var(--card-glass); backdrop-filter: blur(20px); -webkit-backdrop-filter: blur(20px);
            width: 100%; max-width: 100%; min-height: 100vh; padding: 20px 20px 30px 20px; box-sizing: border-box; 
            text-align: center; border: none; position: relative; animation: floatUp 0.8s ease-out;
            display: flex; flex-direction: column; 
        }

        @keyframes floatUp { from { opacity: 0; transform: translateY(30px); } to { opacity: 1; transform: translateY(0); } }
        
        .flex-center { display: flex; align-items: center; justify-content: center; }
        
        #toastBox {
            position: fixed; bottom: 30px; left: 50%; transform: translateX(-50%);
            background: rgba(22, 24, 35, 0.95); border: 1px solid var(--border-glass);
            color: white; padding: 12px 25px; border-radius: 50px; z-index: 100000;
            display: none; align-items: center; gap: 10px; font-size: 14px; font-weight: 500;
            box-shadow: 0 10px 30px rgba(0,0,0,0.8); backdrop-filter: blur(10px);
            animation: toastFade 0.3s ease forwards; white-space: nowrap;
        }
        @keyframes toastFade { 
            from { opacity: 0; transform: translate(-50%, 20px); } 
            to { opacity: 1; transform: translate(-50%, 0); } 
        }
        .toast-img { width: 28px; height: 28px; border-radius: 50%; object-fit: cover; display: none; border: 1px solid rgba(255,255,255,0.2); }

        .hamburger-btn {
            background: transparent; border: none; color: var(--neon-yellow); cursor: pointer; 
            width: 50px; height: 50px; display: flex; justify-content: center; align-items: center; 
            transition: 0.2s; filter: drop-shadow(0 2px 5px rgba(0,0,0,0.8)); -webkit-tap-highlight-color: transparent;
        }
        .hamburger-btn:active { transform: scale(0.9); }
        .hamburger-btn .material-symbols-outlined { font-size: 38px !important; }

        .side-menu-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.7); z-index: 100000; display: none; opacity: 0; transition: opacity 0.3s; backdrop-filter: blur(5px); }
        .side-menu { position: fixed; top: 0; right: -320px; width: 280px; height: 100%; background: #0d0f17; border-left: 1px solid rgba(255,255,255,0.05); box-shadow: -10px 0 40px rgba(0,0,0,0.9); transition: right 0.3s ease-in-out; display: flex; flex-direction: column; padding: 40px 20px; box-sizing: border-box; }
        .side-menu-header { text-align: center; margin-bottom: 25px; }
        .side-profile-pic { width: 90px; height: 90px; border-radius: 50%; border: 3px solid #f1c40f; box-shadow: 0 0 15px rgba(241, 196, 15, 0.4); object-fit: cover; cursor: pointer; margin-bottom: 15px; transition: 0.3s; background: rgba(0,0,0,0.3); }
        .side-profile-pic:active { transform: scale(0.95); }
