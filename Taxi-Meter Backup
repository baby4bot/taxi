        .bubble-bg-container { position: absolute; top: 50%; left: 50%; transform: translate(-50%, -50%); width: 100%; height: 100%; z-index: 0; pointer-events: none; overflow: visible; }
        .bubble { position: absolute; border-radius: 50%; animation: floatBubble 8s ease-in-out infinite; mix-blend-mode: screen; filter: blur(15px); }
        .bubble-1 { width: 180px; height: 180px; top: -30px; left: 5%; background: rgba(46, 204, 113, 0.8); }
        .bubble-2 { width: 200px; height: 200px; bottom: -40px; right: -5%; background: rgba(255, 71, 87, 0.8); animation-delay: -2s; }
        .bubble-3 { width: 160px; height: 160px; top: 40px; left: 40%; background: rgba(241, 196, 15, 0.8); animation-delay: -4s; }
        .bubble-4 { width: 170px; height: 170px; top: -10px; right: 15%; background: rgba(255, 152, 0, 0.8); animation-delay: -1s; }
        .bubble-5 { width: 190px; height: 190px; bottom: 0px; left: 20%; background: rgba(0, 191, 255, 0.8); animation-delay: -3s; }
        .bubble-6 { width: 170px; height: 170px; top: 45%; left: -10%; background: rgba(155, 89, 182, 0.8); animation-delay: -5s; }
        @keyframes floatBubble { 0%, 100% { transform: translateY(0) scale(1); } 50% { transform: translateY(-15px) scale(1.05); } }
        
        .result-content { position: relative; z-index: 10; text-align: center; transition: 0.3s; }
        .price { font-size: 68px; font-weight: 600; line-height: 1; color: #fff; text-shadow: 0 4px 15px rgba(0,0,0,0.8), 0 0 20px rgba(46, 204, 113, 0.5); }
        .sub-info { font-size: 16px; font-weight: 500; margin-top: 15px; color: #fff; text-shadow: 0 2px 5px rgba(0,0,0,0.8); background: rgba(10, 12, 18, 0.7); border: 1px solid rgba(255,255,255,0.15); padding: 6px 18px; border-radius: 20px; display: inline-block; backdrop-filter: blur(8px); box-shadow: 0 4px 10px rgba(0,0,0,0.3); }

        .action-row { display: flex; gap: 10px; margin-bottom: 12px; width: 100%; flex-shrink: 0; }
        .manual-timer-btn { flex: 1; padding: 18px 20px; border-radius: 20px; background: var(--neon-green); color: white; border: none; cursor: pointer; font-family: 'Kanit', sans-serif; font-size: 16px; font-weight: 600; transition: 0.3s; display: flex; justify-content: center; align-items: center; gap: 8px; box-shadow: 0 4px 15px rgba(46, 204, 113, 0.3); -webkit-user-select: none; user-select: none; }
        .manual-timer-btn:active { transform: scale(0.98); }
        .manual-timer-btn.active { background: var(--accent-red); box-shadow: 0 4px 15px rgba(255, 71, 87, 0.4); padding: 12px 20px; justify-content: space-between; }

        .small-nav-btn { width: 60px; height: 60px; border-radius: 20px; background: #4285F4; border: none; cursor: pointer; flex-shrink: 0; display: none; justify-content: center; align-items: center; box-shadow: 0 4px 15px rgba(66, 133, 244, 0.4); transition: 0.3s; }
        .small-nav-btn:active { transform: scale(0.95); }
        .small-nav-btn img { width: 30px; height: 30px; filter: drop-shadow(0 2px 5px rgba(0,0,0,0.3)); }

        .btn-reset { flex-shrink: 0; width: 100%; padding: 18px; border: none; border-radius: 20px; font-size: 16px; font-weight: 600; cursor: pointer; transition: 0.3s; background: var(--accent-red); color: white; box-shadow: 0 4px 15px rgba(255, 71, 87, 0.3); margin-bottom: 20px; }

        .btn-icon-base { background: var(--input-bg); border: 1px solid var(--border-glass); border-radius: 20px; width: 60px; height: 60px; cursor: pointer; transition: 0.3s; box-shadow: inset 0 2px 5px rgba(0,0,0,0.5); }
        .footer-credit { margin-top: auto; padding-top: 15px; border-top: 1px solid var(--border-glass); gap: 8px; font-size: 12px; color: var(--text-dim); width: 100%; justify-content: center; flex-shrink: 0;}
        .footer-logo { width: 22px; height: 22px; border-radius: 50%; }
        
        .modal-overlay { position: fixed; top: 0; left: 0; width: 100%; height: 100%; background: rgba(0,0,0,0.85); display: none; justify-content: center; align-items: center; z-index: 9999; backdrop-filter: blur(15px); animation: fadeIn 0.3s; overflow: hidden; }
        @keyframes fadeIn { from { opacity: 0; } to { opacity: 1; } }
        
        .modal-box.flex-col-box { background: var(--bg-dark); border: 1px solid var(--border-glass); border-radius: 30px; width: 95%; max-width: 500px; height: 85vh; display: flex; flex-direction: column; overflow: hidden; padding: 0; position: relative; transform: scale(0.9); animation: popIn 0.3s forwards; }
        @keyframes popIn { to { transform: scale(1); } }
        
        .modal-header { position: relative; padding: 20px; flex-shrink: 0; border-bottom: 1px solid rgba(255,255,255,0.05); text-align: center; }
